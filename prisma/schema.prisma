// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String       @id @unique @default(uuid())
  telegramId         Int          @unique
  lang               Language?
  name               String?
  phone              String?
  inn                String?
  state              UserState    @default(WAIT_LANGUAGE)
  pendingRequestType RequestType?
  pendingAppealDomain    String?
  pendingAppealSubdomain String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  requests           Request[]
}

model Request {
  id            String        @id @unique @default(uuid())
  requestNumber String        @unique
  userId        String
  type          RequestType
  domain        String?
  subdomain     String?
  text          String?
  status        RequestStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  attachments RequestAttachment[]
}

model RequestAttachment {
  id             String         @id @default(uuid())
  requestId      String
  telegramFileId String
  fileUrl        String?
  type           AttachmentType
  fileName       String?
  mimeType       String?
  fileSize       Int?
  createdAt      DateTime       @default(now())

  request Request @relation(fields: [requestId], references: [id])
}

enum Language {
  RU
  UZ
  EN
}

enum UserState {
  WAIT_LANGUAGE
  WAIT_CONTACT
  WAIT_INN
  READY_FOR_REQUEST_TYPE
  WAIT_APPEAL_DOMAIN
  WAIT_APPEAL_SUBDOMAIN
  WAIT_REQUEST_CONTENT
  REQUEST_CREATED
}

enum RequestType {
  APPEAL
  IMPROVEMENT
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  REJECTED
  CLOSED
}

enum AttachmentType {
  PHOTO
  VIDEO
}
