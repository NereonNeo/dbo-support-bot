{
  "name": "dbo-support-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "export DEBUG='grammy*' && tsx watch ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "format": "prettier --write \"src/**/*.ts\" ",
    "prisma:migrate": "prisma migrate dev --config ./src/app/db/prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config ./src/app/db/prisma.config.ts",
    "prisma:generate": "prisma generate --config ./src/app/db/prisma.config.ts",
    "prisma:validate": "prisma validate --config ./src/app/db/prisma.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "grammy": "^1.41.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
